// ==UserScript==
// @name        Poxel.io 玩家高亮與平滑追蹤器
// @namespace   Violentmonkey Scripts
// @match       *://poxel.io/*
// @grant       none
// @version     1.2
// @author      Gemini
// @description 玩家高亮、平滑鏡頭追蹤、以及點位視覺化輔助。
// ==/UserScript==

(function() {
    'use strict';

    // --- 參數設定 ---
    const settings = {
        dotColor: '#00FF00',   // 視覺化小點顏色 (螢光綠)
        dotSize: 10,           // 小點大小
        smoothness: 0.1,       // 鏡頭平滑度 (越小越慢/越順)
        highlightColor: 0xff0000, // 高亮顏色 (紅色)
        presetPoint: { x: window.innerWidth / 2, y: window.innerHeight / 2 },
        isTrackingPreset: false
    };

    // --- 1. 建立視覺化小點 (Visualizer Dot) ---
    // 這會在你追蹤的目標（玩家頭部或預設點）上顯示一個點
    const visualDot = document.createElement('div');
    visualDot.style.cssText = `
        position: absolute;
        width: ${settings.dotSize}px;
        height: ${settings.dotSize}px;
        background: ${settings.dotColor};
        border-radius: 50%;
        border: 2px solid white;
        pointer-events: none;
        z-index: 10000;
        display: none;
        transform: translate(-50%, -50%);
        box-shadow: 0 0 10px ${settings.dotColor};
    `;
    document.body.appendChild(visualDot);

    // --- 2. 獲取遊戲目標 (Hooking) ---
    // 這裡需要針對遊戲的混淆代碼進行配對
    function getTargetPosition() {
        // 嘗試尋找遊戲內部的玩家物件 (通常在 window.game 或 window.world)
        const game = window.game || window.app;
        if (game && game.players) {
            const playerArray = Object.values(game.players);
            if (playerArray.length > 0) {
                // 回傳第一個玩家的畫面座標 (需根據遊戲內建轉換函式)
                return playerArray[0].screenPos || playerArray[0].position;
            }
        }
        return settings.isTrackingPreset ? settings.presetPoint : null;
    }

    // --- 3. 核心邏輯：平滑相機與繪製 ---
    let currentPos = { x: window.innerWidth / 2, y: window.innerHeight / 2 };

    function renderLoop() {
        const target = getTargetPosition();

        if (target) {
            // 平滑插值計算 (LERP)
            currentPos.x += (target.x - currentPos.x) * settings.smoothness;
            currentPos.y += (target.y - currentPos.y) * settings.smoothness;

            // 更新視覺化小點位置
            visualDot.style.display = 'block';
            visualDot.style.left = `${currentPos.x}px`;
            visualDot.style.top = `${currentPos.y}px`;

            // 在這裡加入高亮邏輯 (ESP)
            // 如果能存取 Three.js 物件： player.mesh.material.emissive.set(settings.highlightColor);
        } else {
            visualDot.style.display = 'none';
        }

        requestAnimationFrame(renderLoop);
    }

    // --- 4. 額外功能 (你需要的其他函式) ---

    // [功能 A]：切換預設點位
    window.addEventListener('keydown', (e) => {
        if (e.key === 't') { // 按下 T 鍵切換
            settings.isTrackingPreset = !settings.isTrackingPreset;
            console.log("預設點位追蹤:", settings.isTrackingPreset);
        }
    });

    // [功能 B]：距離標籤 (顯示目標多遠)
    const infoTag = document.createElement('div');
    infoTag.style.cssText = "position:absolute; color:white; font-family:monospace; pointer-events:none;";
    document.body.appendChild(infoTag);

    function updateInfo(target) {
        if (target) {
            infoTag.style.left = `${currentPos.x + 15}px`;
            infoTag.style.top = `${currentPos.y}px`;
            infoTag.innerText = `TARGET: ACTIVE`;
        } else {
            infoTag.innerText = "";
        }
    }

    // 啟動循環
    renderLoop();
    console.log("Poxel.io 輔助腳本已載入。按 'T' 切換預設點追蹤。");

})();
