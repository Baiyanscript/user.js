// 探测游戏对象存在的路径
console.log('=== 探测游戏对象 ===');
console.log('window.game:', window.game);
console.log('window.pixelio:', window.pixelio);
console.log('window.PixelIO:', window.PixelIO);
console.log('window._game:', window._game);
console.log('window.client:', window.client);
console.log('window.renderer:', window.renderer);
console.log('window.__GAME__:', window.__GAME__);

// 遍历 window 下可能的关键词
const keywords = ['game', 'pixel', 'client', 'player', 'camera', 'render', 'engine', 'app'];
console.log('=== 可能的游戏对象 ===');
keywords.forEach(kw => {
    for (let key in window) {
        if (key.toLowerCase().includes(kw)) {
            console.log(`找到: ${key}`, window[key]);
        }
    }
});
