// ==UserScript==
// @name         Poxel.io ESP + Debug Aim Overlay
// @namespace    http://tampermonkey.net/
// @version      1.0
// @description  Player highlight + FOV/debug overlay for Poxel.io
// @author       ChatGPT
// @match        *://poxel.io/*
// @grant        none
// ==/UserScript==

(function () {
    'use strict';

    const settings = {
        esp: true,
        showLines: true,
        showBoxes: true,
        showFov: true,
        fovRadius: 180,

        lineWidth: 2,
        boxColor: '#ff0000',
        lineColor: '#00ff00',
        fovColor: '#ffffff'
    };

    // Overlay
    const overlay = document.createElement('canvas');
    overlay.width = window.innerWidth;
    overlay.height = window.innerHeight;
    overlay.style.position = 'fixed';
    overlay.style.left = '0';
    overlay.style.top = '0';
    overlay.style.pointerEvents = 'none';
    overlay.style.zIndex = '999999';

    document.body.appendChild(overlay);

    const ctx = overlay.getContext('2d');

    window.addEventListener('resize', () => {
        overlay.width = window.innerWidth;
        overlay.height = window.innerHeight;
    });

    // Demo player cache
    // Replace with actual game entities if you reverse the game structures
    let fakePlayers = [];

    function randomPlayers() {
        fakePlayers = [];

        for (let i = 0; i < 12; i++) {
            fakePlayers.push({
                x: Math.random() * window.innerWidth,
                y: Math.random() * window.innerHeight,
                w: 40,
                h: 80
            });
        }
    }

    randomPlayers();

    setInterval(randomPlayers, 1500);

    function drawFov() {
        if (!settings.showFov) return;

        ctx.beginPath();
        ctx.arc(
            window.innerWidth / 2,
            window.innerHeight / 2,
            settings.fovRadius,
            0,
            Math.PI * 2
        );

        ctx.strokeStyle = settings.fovColor;
        ctx.lineWidth = 1;
        ctx.stroke();
    }

    function drawPlayers() {
        fakePlayers.forEach(player => {

            // Box
            if (settings.showBoxes) {
                ctx.strokeStyle = settings.boxColor;
                ctx.lineWidth = settings.lineWidth;

                ctx.strokeRect(
                    player.x,
                    player.y,
                    player.w,
                    player.h
                );
            }

            // Snapline
            if (settings.showLines) {
                ctx.beginPath();

                ctx.moveTo(
                    window.innerWidth / 2,
                    window.innerHeight
                );

                ctx.lineTo(
                    player.x + player.w / 2,
                    player.y + player.h / 2
                );

                ctx.strokeStyle = settings.lineColor;
                ctx.stroke();
            }
        });
    }

    function render() {
        ctx.clearRect(0, 0, overlay.width, overlay.height);

        drawFov();
        drawPlayers();

        requestAnimationFrame(render);
    }

    render();

    console.log('[Poxel.io Debug Overlay Loaded]');
})();
