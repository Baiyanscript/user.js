// ==UserScript==
// @name        Poxel.io Enhanced Visuals & Camera
// @namespace   Violentmonkey Scripts
// @match       *://poxel.io/*
// @grant       none
// @version     1.0
// @author      Gemini
// @description Highlights players, smooth camera tracking, and point visualization.
// ==/UserScript==

(function() {
    'use strict';

    // --- Configuration & State ---
    const config = {
        highlightColor: '#ff0000',
        dotColor: '#00ff00',
        dotSize: 8,
        smoothness: 0.1, // Lower is smoother/slower
        usePresetPoint: false,
        presetPoint: { x: 0, y: 0, z: 0 },
        espEnabled: true
    };

    // Placeholder for game objects (Names depend on game's specific engine)
    let players = [];
    let camera = null;

    // --- 1. Visualizer: The "Point Dot" ---
    // This creates a 2D overlay to visualize 3D points on your screen.
    function createVisualDot() {
        const dot = document.createElement('div');
        dot.id = 'point-visualizer-dot';
        dot.style.cssText = `
            position: absolute;
            width: ${config.dotSize}px;
            height: ${config.dotSize}px;
            background: ${config.dotColor};
            border-radius: 50%;
            pointer-events: none;
            display: none;
            z-index: 9999;
            box-shadow: 0 0 10px ${config.dotColor};
        `;
        document.body.appendChild(dot);
        return dot;
    }
    const visualDot = createVisualDot();

    // --- 2. Highlight Logic (ESP) ---
    // Draws boxes or outlines around player entities.
    function applyHighlights() {
        if (!config.espEnabled) return;

        players.forEach(player => {
            if (player.mesh) {
                // Logic to set emissive color or wireframe on the player model
                player.mesh.material.emissive.set(config.highlightColor);
                player.mesh.material.emissiveIntensity = 0.5;
            }
        });
    }

    // --- 3. Smooth Camera Tracking ---
    function updateCamera() {
        let targetPoint;

        if (config.usePresetPoint) {
            targetPoint = config.presetPoint;
        } else if (players.length > 0) {
            // Target the first player's head area
            targetPoint = players[0].position;
        }

        if (targetPoint && camera) {
            // Linear Interpolation (Lerp) for smoothness
            camera.position.x += (targetPoint.x - camera.position.x) * config.smoothness;
            camera.position.y += (targetPoint.y - camera.position.y) * config.smoothness;
            camera.position.z += (targetPoint.z - camera.position.z) * config.smoothness;

            camera.lookAt(targetPoint.x, targetPoint.y, targetPoint.z);
        }
    }

    // --- 4. World-to-Screen Helper ---
    // Updates the visual dot's position based on the 3D target
    function updateVisualizer(target) {
        if (!target) {
            visualDot.style.display = 'none';
            return;
        }

        // Note: This requires the game's projection matrix to convert 3D to 2D
        // This is a pseudocode representation of that conversion
        const screenPos = projectToScreen(target);

        visualDot.style.display = 'block';
        visualDot.style.left = `${screenPos.x}px`;
        visualDot.style.top = `${screenPos.y}px`;
    }

    // --- Main Loop ---
    function gameTick() {
        applyHighlights();
        updateCamera();
        // Update dot for the current active target
        updateVisualizer(config.usePresetPoint ? config.presetPoint : players[0]?.position);

        requestAnimationFrame(gameTick);
    }

    // Initialize
    console.log("Poxel Helper Loaded. Press 'P' to toggle Preset Point.");

    window.addEventListener('keydown', (e) => {
        if (e.key.toLowerCase() === 'p') {
            config.usePresetPoint = !config.usePresetPoint;
            console.log("Preset Point Mode:", config.usePresetPoint);
        }
    });

    // Start loop
    requestAnimationFrame(gameTick);

})();
