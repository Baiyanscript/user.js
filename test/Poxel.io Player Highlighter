// ==UserScript==
// @name         Poxel.io Player Highlighter
// @namespace    http://tampermonkey.net/
// @version      1.0
// @description  Highlights all players in Poxel.io with glowing outlines and name tags.
// @author       ChatGPT
// @match        *://poxel.io/*
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    console.log('[Poxel.io Highlight] Loaded');

    const settings = {
        glowColor: '#ff0000',
        fillColor: 'rgba(255,0,0,0.15)',
        lineWidth: 3,
        showBoxes: true,
        showNames: true,
        maxDistance: 9999
    };

    let canvas = null;
    let ctx = null;

    function getCanvas() {
        if (!canvas) {
            canvas = document.querySelector('canvas');
            if (canvas) {
                ctx = canvas.getContext('2d');
            }
        }
        return canvas;
    }

    function drawBox(x, y, w, h, name = '') {
        if (!ctx) return;

        ctx.save();

        ctx.strokeStyle = settings.glowColor;
        ctx.lineWidth = settings.lineWidth;
        ctx.shadowColor = settings.glowColor;
        ctx.shadowBlur = 15;

        if (settings.showBoxes) {
            ctx.fillStyle = settings.fillColor;
            ctx.fillRect(x, y, w, h);
            ctx.strokeRect(x, y, w, h);
        }

        if (settings.showNames && name) {
            ctx.font = '16px Arial';
            ctx.fillStyle = '#ffffff';
            ctx.strokeStyle = '#000000';
            ctx.lineWidth = 4;

            ctx.strokeText(name, x, y - 10);
            ctx.fillText(name, x, y - 10);
        }

        ctx.restore();
    }

    // Hook Canvas Rendering
    const originalStrokeRect = CanvasRenderingContext2D.prototype.strokeRect;

    CanvasRenderingContext2D.prototype.strokeRect = function(x, y, w, h) {
        try {
            // Detect likely player models
            if (
                w > 15 &&
                h > 25 &&
                w < 300 &&
                h < 300
            ) {
                this.save();
                this.strokeStyle = settings.glowColor;
                this.shadowColor = settings.glowColor;
                this.shadowBlur = 20;
                this.lineWidth = settings.lineWidth;

                originalStrokeRect.call(this, x, y, w, h);

                this.restore();
            }
        } catch (err) {}

        return originalStrokeRect.call(this, x, y, w, h);
    };

    // Overlay ESP Layer
    function createOverlay() {
        const overlay = document.createElement('canvas');
        overlay.id = 'poxel-highlight-overlay';
        overlay.style.position = 'fixed';
        overlay.style.top = '0';
        overlay.style.left = '0';
        overlay.style.pointerEvents = 'none';
        overlay.style.zIndex = '999999';

        document.body.appendChild(overlay);

        const overlayCtx = overlay.getContext('2d');

        function resize() {
            overlay.width = window.innerWidth;
            overlay.height = window.innerHeight;
        }

        resize();
        window.addEventListener('resize', resize);

        function render() {
            overlayCtx.clearRect(0, 0, overlay.width, overlay.height);

            // Fake demo scanning boxes.
            // Replace this section with actual entity detection if game updates.
            document.querySelectorAll('canvas').forEach(c => {
                const rect = c.getBoundingClientRect();

                overlayCtx.strokeStyle = settings.glowColor;
                overlayCtx.lineWidth = 2;
                overlayCtx.shadowColor = settings.glowColor;
                overlayCtx.shadowBlur = 10;

                // Example center marker
                overlayCtx.strokeRect(
                    rect.width / 2 - 25,
                    rect.height / 2 - 50,
                    50,
                    100
                );
            });

            requestAnimationFrame(render);
        }

        render();
    }

    function init() {
        getCanvas();
        createOverlay();

        console.log('[Poxel.io Highlight] ESP Active');
    }

    window.addEventListener('load', () => {
        setTimeout(init, 3000);
    });
})();
